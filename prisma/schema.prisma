generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String         @unique
  emailVerified DateTime?
  image         String?
  username      String?        @unique
  password      String?
  role          UserRole       @default(USER)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  accounts      Account[]
  comments      Comment[]
  entries       Entry[]        @relation("EntryAuthor")
  entryVersions EntryVersion[]
  families      FamilyMember[]
  likes         Like[]
  media         Media[]
  sessions      Session[]

  @@map("users")
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
  @@map("verification_tokens")
}

model Family {
  id        String         @id @default(cuid())
  name      String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  children  Child[]
  entries   Entry[]
  members   FamilyMember[]

  @@map("families")
}

model FamilyMember {
  id        String     @id @default(cuid())
  userId    String
  familyId  String
  role      FamilyRole @default(MEMBER)
  createdAt DateTime   @default(now())
  family    Family     @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, familyId])
  @@index([familyId])
  @@map("family_members")
}

model Child {
  id            String       @id @default(cuid())
  name          String
  birthDate     DateTime
  gender        Gender?
  image         String?
  familyId      String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  family        Family       @relation(fields: [familyId], references: [id], onDelete: Cascade)
  taggedEntries EntryChild[]

  @@index([familyId])
  @@index([birthDate])
  @@map("children")
}

model Entry {
  id             String         @id @default(cuid())
  title          String
  content        String
  eventDate      DateTime
  location       String?
  category       Category       @default(DAILY_LIFE)
  visibility     Visibility     @default(FAMILY_ONLY)
  authorId       String
  familyId       String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  comments       Comment[]
  author         User           @relation("EntryAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  family         Family         @relation(fields: [familyId], references: [id], onDelete: Cascade)
  taggedChildren EntryChild[]
  versions       EntryVersion[]
  likes          Like[]
  media          Media[]

  @@index([familyId])
  @@index([authorId])
  @@index([eventDate])
  @@index([category])
  @@map("entries")
}

model EntryChild {
  id      String @id @default(cuid())
  entryId String
  childId String
  child   Child  @relation(fields: [childId], references: [id], onDelete: Cascade)
  entry   Entry  @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@unique([entryId, childId])
  @@index([childId])
  @@map("entry_children")
}

model EntryVersion {
  id        String   @id @default(cuid())
  entryId   String
  version   Int
  title     String
  content   String
  eventDate DateTime
  location  String?
  editedBy  String
  editedAt  DateTime @default(now())
  category  Category
  editor    User     @relation(fields: [editedBy], references: [id])
  entry     Entry    @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@unique([entryId, version])
  @@index([entryId])
  @@index([editedAt])
  @@map("entry_versions")
}

model Media {
  id         String    @id @default(cuid())
  url        String
  type       MediaType
  fileName   String?
  fileSize   Int?
  mimeType   String?
  entryId    String
  uploadedBy String
  createdAt  DateTime  @default(now())
  entry      Entry     @relation(fields: [entryId], references: [id], onDelete: Cascade)
  uploader   User      @relation(fields: [uploadedBy], references: [id])

  @@index([entryId])
  @@index([uploadedBy])
  @@map("media")
}

model Like {
  id        String   @id @default(cuid())
  userId    String
  entryId   String
  createdAt DateTime @default(now())
  entry     Entry    @relation(fields: [entryId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, entryId])
  @@index([entryId])
  @@map("likes")
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  userId    String
  entryId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  entry     Entry    @relation(fields: [entryId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([entryId])
  @@map("comments")
}

enum UserRole {
  SUPER_ADMIN
  USER
}

enum FamilyRole {
  OWNER
  PARTNER
  MEMBER
  VIEWER
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum Category {
  MILESTONE
  DAILY_LIFE
  SPECIAL_EVENT
  HEALTH
  EDUCATION
  FAMILY
  TRAVEL
  OTHER
}

enum Visibility {
  PRIVATE
  FAMILY_ONLY
  PUBLIC
}

enum MediaType {
  IMAGE
  VIDEO
}
